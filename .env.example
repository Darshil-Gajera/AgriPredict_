# ── AgriPredict .env ─────────────────────────────────────────
# Copy this to .env and fill in real values before running.

# Django
SECRET_KEY=django-insecure-CHANGE-THIS-TO-A-LONG-RANDOM-STRING
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,gajera06.pythonanywhere.com
DATABASE_URL=sqlite:///db.sqlite3

# Chatbot
CHATBOT_API_URL=http://chatbot:8001
CHATBOT_GOOGLE_API_KEY=write
CHATBOT_VECTOR_STORE_PATH=./data/vector_store
CHATBOT_LLM_MODEL=gemini-2.5-flash
INGEST_SECRET=change-me-random-secret

# Redis (for Celery)
REDIS_URL=redis://redis:6379/0

# Email — Mailtrap (dev) → swap for real SMTP in prod
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=write@smtp-brevo.com
EMAIL_HOST_PASSWORD=xsmtpsib-write
DEFAULT_FROM_EMAIL=AgriPredict <write email>


# Twilio SMS (optional — leave blank to disable SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://chatbot:8001